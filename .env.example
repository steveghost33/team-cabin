# No environment variables are required for local development.
# Add non-secret client-side Vite variables here as VITE_* examples only.

# Leaderboard API (Flask backend). Defaults to localhost:5000 in dev.
# Set to your deployed Render URL in production (Vercel env vars dashboard).
# Local dev (macOS AirPlay takes 5000, so Flask runs on 5001 by default):
# VITE_API_URL=http://localhost:5001
# Production:
# VITE_API_URL=https://your-app.onrender.com
